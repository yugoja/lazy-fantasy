# Fantasy Cricket League - Backend Environment Variables
# Copy this file to .env and fill in values for your environment

# JWT Configuration
SECRET_KEY=your-secure-secret-key-minimum-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Database URL
# For local development (SQLite):
DATABASE_URL=sqlite:///./fantasy_cricket.db
# For production (PostgreSQL on Render):
# DATABASE_URL=postgresql://user:password@host:5432/database_name

# CORS Configuration (comma-separated for multiple origins)
CORS_ORIGINS=http://localhost:3000
# For production:
# CORS_ORIGINS=https://your-frontend.onrender.com

# Frontend URL (for generating links, etc.)
FRONTEND_URL=http://localhost:3000
# For production:
# FRONTEND_URL=https://your-frontend.onrender.com

# Sentry Error Tracking (optional — leave blank to disable)
SENTRY_DSN=
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.1
