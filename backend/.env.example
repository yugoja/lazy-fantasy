# Fantasy Cricket League - Backend Environment Variables
# Copy this file to .env and fill in values for your environment

# JWT Configuration
SECRET_KEY=your-secure-secret-key-minimum-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Database URL
# For local development (SQLite):
DATABASE_URL=sqlite:///./fantasy_cricket.db
# For production (PostgreSQL on Render):
# DATABASE_URL=postgresql://user:password@host:5432/database_name

# CORS Configuration (comma-separated for multiple origins)
CORS_ORIGINS=http://localhost:3000
# For production:
# CORS_ORIGINS=https://your-frontend.onrender.com

# Frontend URL (for generating links, etc.)
FRONTEND_URL=http://localhost:3000
# For production:
# FRONTEND_URL=https://your-frontend.onrender.com

# Google SSO (optional — leave blank to disable Google sign-in)
GOOGLE_CLIENT_ID=263603708357-b4cu91n2qsp1ckbi7d6iv42p4gduf5pv.apps.googleusercontent.com
# Get this from https://console.cloud.google.com/apis/credentials

# Resend — email reminders (https://resend.com, free tier: 3k emails/month)
RESEND_API_KEY=

# Web Push / VAPID — push notifications (optional — leave blank to disable)
# Keys generated once: cd backend && ./venv/bin/python scripts/generate_vapid_keys.py
VAPID_PUBLIC_KEY=BPEtQ2EWNvSTGGd4lyl9Xf1Na4fzHcp9uG4OFZhhiGwxg3eRRYAGz-ZzVlae_1PgnqQkOPfV7-ruGvBAdlx8iqM
VAPID_PRIVATE_KEY=
VAPID_CLAIMS_EMAIL=you@lazyfantasy.app

# Sentry Error Tracking (optional — leave blank to disable)
SENTRY_DSN=
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.1
