# Fantasy Cricket League - Frontend Environment Variables
# Copy this file to .env.local and fill in values for your environment

# API URL - Backend service URL
# For local development:
NEXT_PUBLIC_API_URL=http://localhost:8000

# For production (Render):
# NEXT_PUBLIC_API_URL=https://your-backend-service.onrender.com

# Sentry Error Tracking (optional — leave blank to disable)
NEXT_PUBLIC_SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_ENVIRONMENT=production
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
